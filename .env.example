# Shared
COMPOSE_PROJECT_NAME=workestrator

# PostgreSQL
POSTGRES_DB=workestrator
POSTGRES_USER=workestrator
POSTGRES_PASSWORD=workestrator
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Django core-service
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
INTERNAL_SERVICE_TOKEN=local-dev-internal-service-token
PLANNER_SERVICE_URL=http://localhost:8001
CORE_DB_AUTO_RESET_ON_INCONSISTENT_MIGRATIONS=true

# planner-service
CORE_SERVICE_URL=http://localhost:8000
PLANNER_HOST=0.0.0.0
PLANNER_PORT=8001

# ai-layer
AI_LAYER_URL=http://localhost:8002
AI_LAYER_HOST=0.0.0.0
AI_LAYER_PORT=8002
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_TIMEOUT_SECONDS=90
AI_VECTOR_DIM=1024
AI_TOP_K=5
AI_SYNC_STALE_SECONDS=300
AI_DB_CONNECT_RETRIES=10
AI_DB_CONNECT_RETRY_DELAY_SECONDS=1
