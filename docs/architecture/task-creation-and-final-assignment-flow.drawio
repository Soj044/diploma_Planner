<mxfile host="app.diagrams.net" modified="2026-04-26T12:05:00.000Z" agent="Codex" version="24.7.17" editor="Codex" type="device">
  <diagram id="workestrator-task-flow" name="Task And Approval Flow">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="2" value="Пользователь / менеджер" style="swimlane;horizontal=0;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="350" height="1450" as="geometry"/>
        </mxCell>
        <mxCell id="3" value="core-service" style="swimlane;horizontal=0;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="410" y="20" width="420" height="1450" as="geometry"/>
        </mxCell>
        <mxCell id="4" value="planner-service" style="swimlane;horizontal=0;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="870" y="20" width="430" height="1450" as="geometry"/>
        </mxCell>

        <mxCell id="10" value="1. Войти в систему&lt;br/&gt;/admin/ или DRF API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="2">
          <mxGeometry x="40" y="50" width="260" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="2. Создать отделы, навыки,&lt;br/&gt;сотрудников, графики" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="2">
          <mxGeometry x="40" y="160" width="260" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="3. Создать задачу&lt;br/&gt;POST /api/v1/tasks/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="2">
          <mxGeometry x="40" y="290" width="260" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="13" value="4. Добавить требования к задаче&lt;br/&gt;POST /api/v1/task-requirements/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="2">
          <mxGeometry x="40" y="410" width="260" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="14" value="5. Открыть Swagger planner-service&lt;br/&gt;/docs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="2">
          <mxGeometry x="40" y="540" width="260" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="15" value="6. Запустить планирование&lt;br/&gt;POST /api/v1/plan-runs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="2">
          <mxGeometry x="40" y="660" width="260" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="16" value="7. Получить proposals&lt;br/&gt;из ответа или GET /plan-runs/{id}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="2">
          <mxGeometry x="40" y="800" width="260" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="17" value="8. Выбрать пару&lt;br/&gt;task + employee" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="2">
          <mxGeometry x="40" y="930" width="260" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="18" value="9. Утвердить назначение&lt;br/&gt;POST /api/v1/assignments/approve-proposal/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="2">
          <mxGeometry x="40" y="1050" width="260" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="19" value="10. Просмотреть итоговое назначение&lt;br/&gt;GET /api/v1/assignments/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;" vertex="1" parent="2">
          <mxGeometry x="40" y="1180" width="260" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="30" value="Сохраняет business truth&lt;br/&gt;по задачам и сотрудникам" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="3">
          <mxGeometry x="80" y="180" width="260" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="31" value="Создает Task record" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="3">
          <mxGeometry x="80" y="300" width="260" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="32" value="Создает TaskRequirement records" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="3">
          <mxGeometry x="80" y="425" width="260" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="33" value="Отдает PlanningSnapshot&lt;br/&gt;по внутреннему вызову planner-service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="3">
          <mxGeometry x="80" y="700" width="260" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="34" value="Получает approve request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="3">
          <mxGeometry x="80" y="1065" width="260" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="35" value="Читает persisted plan run&lt;br/&gt;из planner-service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="3">
          <mxGeometry x="80" y="1150" width="260" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="36" value="Валидирует proposal,&lt;br/&gt;создает Assignment + ChangeLog" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;" vertex="1" parent="3">
          <mxGeometry x="80" y="1260" width="260" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="50" value="Получает CreatePlanRunRequest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;" vertex="1" parent="4">
          <mxGeometry x="90" y="675" width="260" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="51" value="POST /api/v1/planning-snapshot/&lt;br/&gt;в core-service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;" vertex="1" parent="4">
          <mxGeometry x="90" y="760" width="260" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="52" value="Eligibility -&gt; Scoring -&gt; CP-SAT&lt;br/&gt;-&gt; Diagnostics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;" vertex="1" parent="4">
          <mxGeometry x="90" y="870" width="260" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="53" value="Сохраняет plan run,&lt;br/&gt;proposals и diagnostics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;" vertex="1" parent="4">
          <mxGeometry x="90" y="990" width="260" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="54" value="Отдает proposals пользователю&lt;br/&gt;и core-service по GET /plan-runs/{id}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;" vertex="1" parent="4">
          <mxGeometry x="90" y="1110" width="260" height="80" as="geometry"/>
