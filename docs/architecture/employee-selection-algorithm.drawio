        <mxCell id="17" value="14. Есть задачи без assignment,&lt;br/&gt;но с eligible candidates?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="650" y="1310" width="200" height="120" as="geometry"/>
